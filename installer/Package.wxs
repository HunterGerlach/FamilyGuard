<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="DAD - Digital Activity Defender"
           Manufacturer="FamilyGuard"
           Version="0.1.0"
           UpgradeCode="E7A1B2C3-D4E5-F6A7-B8C9-D0E1F2A3B4C5"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DAD is already installed."
                  AllowSameVersionUpgrades="yes" />

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="FamilyGuard">

        <!-- Service component with Windows Service registration -->
        <Component Id="ServiceExe" Guid="11111111-1111-1111-1111-111111111111">
          <File Id="ServiceExeFile"
                Source="$(var.ServicePublishDir)\FamilyGuard.Service.exe"
                KeyPath="yes" />

          <ServiceInstall Id="FamilyGuardService"
                          Name="FamilyGuard"
                          DisplayName="FamilyGuard Service"
                          Description="DAD - Digital Activity Defender. Family endpoint guidance service."
                          Type="ownProcess"
                          Start="auto"
                          ErrorControl="normal"
                          Account="LocalSystem" />

          <ServiceControl Id="StartFamilyGuardService"
                          Name="FamilyGuard"
                          Start="install"
                          Stop="both"
                          Remove="uninstall"
                          Wait="yes" />
        </Component>

        <!-- Service dependencies -->
        <Component Id="ServiceDeps" Guid="11111111-1111-1111-1111-111111111112">
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Service.dll" />
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Service.runtimeconfig.json" />
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Domain.dll" />
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Application.dll" />
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Infrastructure.dll" />
          <File Source="$(var.ServicePublishDir)\FamilyGuard.Service.deps.json" />
        </Component>

        <!-- Agent -->
        <Component Id="AgentExe" Guid="22222222-2222-2222-2222-222222222221">
          <File Source="$(var.AgentPublishDir)\FamilyGuard.Agent.exe" KeyPath="yes" />
        </Component>

        <Component Id="AgentDeps" Guid="22222222-2222-2222-2222-222222222222">
          <File Source="$(var.AgentPublishDir)\FamilyGuard.Agent.dll" />
          <File Source="$(var.AgentPublishDir)\FamilyGuard.Agent.runtimeconfig.json" />
          <File Source="$(var.AgentPublishDir)\FamilyGuard.Agent.deps.json" />
        </Component>

        <!-- UI -->
        <Component Id="UIExe" Guid="33333333-3333-3333-3333-333333333331">
          <File Source="$(var.UIPublishDir)\FamilyGuard.UI.exe" KeyPath="yes" />
        </Component>

        <Component Id="UIDeps" Guid="33333333-3333-3333-3333-333333333332">
          <File Source="$(var.UIPublishDir)\FamilyGuard.UI.dll" />
          <File Source="$(var.UIPublishDir)\FamilyGuard.UI.runtimeconfig.json" />
          <File Source="$(var.UIPublishDir)\FamilyGuard.UI.deps.json" />
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- Data directory with proper ACLs -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="FamilyGuard">
        <Component Id="DataDirectory" Guid="44444444-4444-4444-4444-444444444444">
          <CreateFolder>
            <Permission User="Users" GenericRead="yes" GenericExecute="yes" />
            <Permission User="SYSTEM" GenericAll="yes" />
            <Permission User="Administrators" GenericAll="yes" />
          </CreateFolder>
          <RegistryValue Root="HKLM"
                         Key="Software\FamilyGuard"
                         Name="DataPath"
                         Type="string"
                         Value="[DATAFOLDER]"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Feature tree -->
    <Feature Id="Complete" Title="DAD" Level="1">
      <ComponentRef Id="ServiceExe" />
      <ComponentRef Id="ServiceDeps" />
      <ComponentRef Id="AgentExe" />
      <ComponentRef Id="AgentDeps" />
      <ComponentRef Id="UIExe" />
      <ComponentRef Id="UIDeps" />
      <ComponentRef Id="DataDirectory" />
    </Feature>

    <!-- Launch conditions -->
    <Launch Condition="Privileged" Message="Administrator privileges are required to install DAD." />

  </Package>
</Wix>

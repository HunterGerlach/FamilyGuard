<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="DAD - Digital Activity Defender"
           Manufacturer="FamilyGuard"
           Version="$(var.ProductVersion)"
           UpgradeCode="E7A1B2C3-D4E5-F6A7-B8C9-D0E1F2A3B4C5"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DAD is already installed."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Launch conditions -->
    <Launch Condition="Privileged" Message="Administrator privileges are required to install DAD." />
    <Launch Condition="VersionNT64" Message="DAD requires a 64-bit version of Windows." />

    <!-- Install directory — flat, all executables and dependencies together -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="FamilyGuard" />
    </StandardDirectory>

    <!-- Start Menu integration so the tray UI can be launched like a normal Windows app -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DAD - Digital Activity Defender" />
    </StandardDirectory>

    <!-- Data directory with proper ACLs -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="FamilyGuard">
        <Component Id="DataDirectory" Guid="44444444-4444-4444-4444-444444444444">
          <CreateFolder>
            <Permission User="Users" GenericRead="yes" GenericExecute="yes" />
            <Permission User="SYSTEM" GenericAll="yes" />
            <Permission User="Administrators" GenericAll="yes" />
          </CreateFolder>
          <RegistryValue Root="HKLM"
                         Key="Software\FamilyGuard"
                         Name="DataPath"
                         Type="string"
                         Value="[DATAFOLDER]"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Service registration -->
    <Component Id="ServiceRegistration" Directory="INSTALLFOLDER" Guid="11111111-1111-1111-1111-111111111111">
      <File Id="ServiceExeFile"
            Source="$(var.PublishDir)\FamilyGuard.Service.exe"
            KeyPath="yes" />

      <ServiceInstall Id="FamilyGuardService"
                      Name="FamilyGuard"
                      DisplayName="FamilyGuard Service"
                      Description="DAD - Digital Activity Defender. Family endpoint guidance service."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem" />

      <ServiceControl Id="StartFamilyGuardService"
                      Name="FamilyGuard"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!-- Auto-start tray UI on user login -->
    <Component Id="TrayAutoStart" Directory="INSTALLFOLDER" Guid="55555555-5555-5555-5555-555555555555">
      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="FamilyGuard"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]FamilyGuard.UI.exe&quot;"
                     KeyPath="yes" />
    </Component>

    <!-- Start Menu shortcut for launching the interactive tray UI on demand -->
    <Component Id="AppShortcuts" Directory="INSTALLFOLDER" Guid="77777777-7777-7777-7777-777777777777">
      <Shortcut Id="StartMenuShortcut"
                Directory="ApplicationProgramsFolder"
                Name="DAD - Digital Activity Defender"
                Description="Open the DAD tray app"
                Target="[INSTALLFOLDER]FamilyGuard.UI.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKLM"
                     Key="Software\FamilyGuard"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Track installation in registry for upgrade detection -->
    <Component Id="InstallMarker" Directory="INSTALLFOLDER" Guid="66666666-6666-6666-6666-666666666666">
      <RegistryValue Root="HKLM"
                     Key="Software\FamilyGuard"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <RegistryValue Root="HKLM"
                     Key="Software\FamilyGuard"
                     Name="InstallDir"
                     Type="string"
                     Value="[INSTALLFOLDER]" />
    </Component>

    <!-- Feature tree -->
    <Feature Id="Complete" Title="DAD" Level="1">
      <ComponentRef Id="DataDirectory" />
      <ComponentRef Id="ServiceRegistration" />
      <ComponentRef Id="TrayAutoStart" />
      <ComponentRef Id="AppShortcuts" />
      <ComponentRef Id="InstallMarker" />
      <ComponentGroupRef Id="AllFiles" />
    </Feature>

    <!-- Launch tray UI immediately after install/upgrade.
         Uses cmd /c start to run asynchronously in the user's session. -->
    <CustomAction Id="LaunchUI"
                  Directory="INSTALLFOLDER"
                  ExeCommand='cmd.exe /c start "" "[INSTALLFOLDER]FamilyGuard.UI.exe"'
                  Execute="commit"
                  Return="asyncNoWait"
                  Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="LaunchUI" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>
</Wix>

<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="DAD - Digital Activity Defender"
           Manufacturer="FamilyGuard"
           Version="0.1.0"
           UpgradeCode="E7A1B2C3-D4E5-F6A7-B8C9-D0E1F2A3B4C5"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DAD is already installed."
                  AllowSameVersionUpgrades="yes" />

    <!-- Embed cabinet files inside the MSI for single-file distribution -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Launch conditions -->
    <Launch Condition="Privileged" Message="Administrator privileges are required to install DAD." />
    <Launch Condition="VersionNT64" Message="DAD requires a 64-bit version of Windows." />

    <!-- Install directory structure -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="FamilyGuard">
        <Directory Id="SERVICEDIR" Name="service" />
        <Directory Id="AGENTDIR" Name="agent" />
        <Directory Id="UIDIR" Name="ui" />
      </Directory>
    </StandardDirectory>

    <!-- Data directory with proper ACLs -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="FamilyGuard">
        <Component Id="DataDirectory" Guid="44444444-4444-4444-4444-444444444444">
          <CreateFolder>
            <Permission User="Users" GenericRead="yes" GenericExecute="yes" />
            <Permission User="SYSTEM" GenericAll="yes" />
            <Permission User="Administrators" GenericAll="yes" />
          </CreateFolder>
          <RegistryValue Root="HKLM"
                         Key="Software\FamilyGuard"
                         Name="DataPath"
                         Type="string"
                         Value="[DATAFOLDER]"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Service registration (references the exe from harvested ServiceFiles group) -->
    <Component Id="ServiceRegistration" Directory="SERVICEDIR" Guid="11111111-1111-1111-1111-111111111111">
      <File Id="ServiceExeFile"
            Source="$(var.ServicePublishDir)\FamilyGuard.Service.exe"
            KeyPath="yes" />

      <ServiceInstall Id="FamilyGuardService"
                      Name="FamilyGuard"
                      DisplayName="FamilyGuard Service"
                      Description="DAD - Digital Activity Defender. Family endpoint guidance service."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem">
        <ServiceConfig DelayedAutoStart="no"
                       FailureActionsWhen="failedToStop"
                       ResetPeriodInDays="1"
                       RestartServiceDelayInSeconds="60"
                       SecondFailureActionType="restart"
                       ThirdFailureActionType="restart"
                       FirstFailureActionType="restart" />
      </ServiceInstall>

      <ServiceControl Id="StartFamilyGuardService"
                      Name="FamilyGuard"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!-- Feature tree -->
    <Feature Id="Complete" Title="DAD" Level="1">
      <Component Id="DataDirectory" />
      <Component Id="ServiceRegistration" />
      <!-- Harvested component groups — generated by wix heat in release workflow -->
      <ComponentGroupRef Id="ServiceFiles" />
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentGroupRef Id="UIFiles" />
    </Feature>

  </Package>
</Wix>

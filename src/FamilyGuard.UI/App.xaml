<Application x:Class="FamilyGuard.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="FGBlue">#2563EB</Color>
            <Color x:Key="FGInk">#111827</Color>
            <Color x:Key="FGMutedInk">#4B5563</Color>
            <Color x:Key="FGSurface">#F8FAFC</Color>
            <Color x:Key="FGBorder">#D1D5DB</Color>
            <SolidColorBrush x:Key="FGBlueBrush" Color="{StaticResource FGBlue}" />
            <SolidColorBrush x:Key="FGInkBrush" Color="{StaticResource FGInk}" />
            <SolidColorBrush x:Key="FGMutedInkBrush" Color="{StaticResource FGMutedInk}" />
            <SolidColorBrush x:Key="FGSurfaceBrush" Color="{StaticResource FGSurface}" />
            <SolidColorBrush x:Key="FGBorderBrush" Color="{StaticResource FGBorder}" />

            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{StaticResource FGInkBrush}" />
                <Setter Property="Background" Value="White" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="MinWidth" Value="88" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource FGBlueBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource FGBlueBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource FGInkBrush}" />
            </Style>

            <Style x:Key="HelpText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FGMutedInkBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="20" />
            </Style>

            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource FGSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource FGBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <tb:TaskbarIcon x:Key="TrayIcon"
                            ToolTipText="DAD — Digital Activity Defender"
                            MenuActivation="LeftOrRightClick"
                            NoLeftClickDelay="True">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Status" Click="ShowStatus_Click" FontWeight="Bold" />
                        <Separator />
                        <MenuItem Header="Mute Mic Now" Click="MuteNow_Click" />
                        <MenuItem Header="Unmute Mic" Click="UnmuteNow_Click" />
                        <Separator />
                        <MenuItem Header="Settings..." Click="ShowSettings_Click" />
                        <MenuItem Header="Event Log" Click="ShowEventLog_Click" />
                        <Separator />
                        <MenuItem Header="About DAD" Click="ShowAbout_Click" />
                        <Separator />
                        <MenuItem Header="Exit" Click="Exit_Click" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>

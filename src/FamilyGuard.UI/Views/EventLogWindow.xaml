<Window x:Class="FamilyGuard.UI.Views.EventLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Event Log" Height="560" Width="820"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Event Log" Style="{StaticResource PageTitle}" />
        <TextBlock Grid.Row="2" Style="{StaticResource HelpText}"
                   Text="Review policy decisions and app health events. DaD stores only operational metadata, never audio, screenshots, keystrokes, or message contents." />

        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Filter" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource DadMutedInkBrush}" />
                <ComboBox x:Name="EventTypeFilter" Width="220" Margin="0,0,8,0"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All Events" IsSelected="True" />
                    <ComboBoxItem Content="Mic Auto-Muted" />
                    <ComboBoxItem Content="Presence Changes" />
                    <ComboBoxItem Content="Settings Changes" />
                    <ComboBoxItem Content="Service Events" />
                </ComboBox>
                <Button Content="Refresh" Click="Refresh_Click" />
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="6" x:Name="EventGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F8FAFC"
                  BorderBrush="{StaticResource DadBorderBrush}"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimestampUtc, StringFormat='{}{0:HH:mm:ss}'}" Width="100" />
                <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="160" />
                <DataGridTextColumn Header="User" Binding="{Binding WindowsUser}" Width="130" />
                <DataGridTextColumn Header="Policy" Binding="{Binding PolicyId}" Width="170" />
                <DataGridTextColumn Header="Details" Binding="{Binding DetailsDisplay}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

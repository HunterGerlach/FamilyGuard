<Window x:Class="FamilyGuard.UI.Views.EventLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Event Log" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Event Log" FontSize="20" FontWeight="SemiBold" />

        <!-- Filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="EventTypeFilter" Width="200" Margin="0,0,8,0"
                      SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="All Events" IsSelected="True" />
                <ComboBoxItem Content="Mic Auto-Muted" />
                <ComboBoxItem Content="Presence Changes" />
                <ComboBoxItem Content="Settings Changes" />
                <ComboBoxItem Content="Service Events" />
            </ComboBox>
            <Button Content="Refresh" Padding="8,4" Click="Refresh_Click" />
        </StackPanel>

        <!-- Event List -->
        <DataGrid Grid.Row="4" x:Name="EventGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F8F8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding TimestampUtc, StringFormat='{}{0:HH:mm:ss}'}" Width="80" />
                <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="160" />
                <DataGridTextColumn Header="User" Binding="{Binding WindowsUser}" Width="100" />
                <DataGridTextColumn Header="Policy" Binding="{Binding PolicyId}" Width="180" />
                <DataGridTextColumn Header="Details" Binding="{Binding DetailsDisplay}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

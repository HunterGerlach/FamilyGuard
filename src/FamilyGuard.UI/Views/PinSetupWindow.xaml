<Window x:Class="FamilyGuard.UI.Views.PinSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Parent PIN Setup" Height="390" Width="520"
        MinHeight="390" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to DaD" Style="{StaticResource PageTitle}" />
        <TextBlock Grid.Row="2" Style="{StaticResource HelpText}"
                   Text="Create a parent PIN to protect settings. Children can see that DaD is running, but they cannot change monitoring rules without this PIN." />

        <Border Grid.Row="4" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Parent PIN" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="Use at least 4 characters. Choose something memorable and do not share it with covered child accounts." Style="{StaticResource HelpText}" Margin="0,0,0,14" />

                <TextBlock Text="Create PIN" Margin="0,0,0,4" />
                <PasswordBox x:Name="PinBox" MaxLength="64" Width="220" MinHeight="34" HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="0,0,0,12" />

                <TextBlock Text="Confirm PIN" Margin="0,0,0,4" />
                <PasswordBox x:Name="ConfirmPinBox" MaxLength="64" Width="220" MinHeight="34" HorizontalAlignment="Left" VerticalContentAlignment="Center" />

                <TextBlock x:Name="ErrorText" Foreground="#B91C1C" Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Set PIN" Style="{StaticResource PrimaryButton}" Click="SetPin_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="FamilyGuard.UI.Views.PinSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Parent PIN Setup" Height="280" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to DaD" FontSize="20" FontWeight="SemiBold" />

        <TextBlock Grid.Row="2" TextWrapping="Wrap">
            Set a parent PIN to protect settings. Children can see DaD is running,
            but cannot change monitoring settings without this PIN.
        </TextBlock>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Create PIN:" Margin="0,0,0,4" />
            <PasswordBox x:Name="PinBox" MaxLength="20" Width="200" HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Confirm PIN:" Margin="0,0,0,4" />
            <PasswordBox x:Name="ConfirmPinBox" MaxLength="20" Width="200" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock Grid.Row="8" x:Name="ErrorText" Foreground="Red" Visibility="Collapsed" />

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Set PIN" Padding="16,6" Click="SetPin_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

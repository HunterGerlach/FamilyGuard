<Window x:Class="FamilyGuard.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Settings" Height="560" Width="620"
        MinHeight="540" MinWidth="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
            <Border DockPanel.Dock="Right" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="12" Padding="10,4">
                <TextBlock Text="Parent PIN required" FontSize="12" Foreground="#92400E" FontWeight="SemiBold" />
            </Border>
        </DockPanel>
        <TextBlock Grid.Row="2" Style="{StaticResource HelpText}"
                   Text="Settings are protected so children can see DaD is running without changing family safety rules." />

        <Border Grid.Row="4" Style="{StaticResource Card}" x:Name="PinPanel">
            <StackPanel>
                <TextBlock Text="Unlock settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="Enter the parent PIN to view and change protected options." Style="{StaticResource HelpText}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <PasswordBox x:Name="PinBox" Width="180" MinHeight="34" Margin="0,0,8,0" MaxLength="64" VerticalContentAlignment="Center" />
                    <Button Content="Unlock" Style="{StaticResource PrimaryButton}" Click="Unlock_Click" IsDefault="True" />
                </StackPanel>
                <TextBlock x:Name="PinError" Foreground="#B91C1C" Margin="0,8,0,0" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="4" x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Presence timeout" Margin="0,0,0,16" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Choose how long the computer must be idle before DaD treats the session as unattended." Style="{StaticResource HelpText}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="TimeoutSlider" Width="320" Minimum="30" Maximum="300"
                                    Value="90" TickFrequency="10" IsSnapToTickEnabled="True" />
                            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <Binding ElementName="TimeoutSlider" Path="Value" StringFormat="{}{0:F0} seconds" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Covered users" Margin="0,0,0,16" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Select the standard Windows user accounts whose sessions should be monitored." Style="{StaticResource HelpText}" Margin="0,0,0,10" />
                        <ListBox x:Name="UserList" Height="110" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Notifications" Padding="12">
                    <StackPanel>
                        <CheckBox Content="Show a quiet toast when DaD auto-mutes the microphone" IsChecked="True" Margin="0,0,0,8" />
                        <CheckBox Content="Show a tray warning when the microphone is open and the user may be away" IsChecked="True" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save changes" Margin="0,0,8,0" x:Name="SaveButton" Style="{StaticResource PrimaryButton}"
                    Visibility="Collapsed" Click="Save_Click" />
            <Button Content="Close" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="FamilyGuard.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaD — Settings" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0" Text="(Parent PIN required)" FontSize="12"
                   VerticalAlignment="Bottom" HorizontalAlignment="Right" Foreground="Gray" />

        <!-- PIN Entry -->
        <StackPanel Grid.Row="2" x:Name="PinPanel">
            <TextBlock Text="Enter Parent PIN to unlock settings:" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal">
                <PasswordBox x:Name="PinBox" Width="150" Margin="0,0,8,0" />
                <Button Content="Unlock" Padding="12,4" Click="Unlock_Click" />
            </StackPanel>
            <TextBlock x:Name="PinError" Foreground="Red" Margin="0,4,0,0" Visibility="Collapsed" />
        </StackPanel>

        <!-- Settings (hidden until unlocked) -->
        <StackPanel Grid.Row="4" x:Name="SettingsPanel" Visibility="Collapsed">
            <TextBlock Text="Presence Timeout" FontWeight="SemiBold" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Consider unattended after:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Slider x:Name="TimeoutSlider" Width="200" Minimum="30" Maximum="300"
                        Value="90" TickFrequency="10" IsSnapToTickEnabled="True" />
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock.Text>
                        <Binding ElementName="TimeoutSlider" Path="Value" StringFormat="{}{0:F0}s" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <TextBlock Text="Covered Users" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Users whose sessions are monitored:" Foreground="Gray" Margin="0,0,0,4" />
            <ListBox x:Name="UserList" Height="100" Margin="0,0,0,16" />

            <TextBlock Text="Notifications" FontWeight="SemiBold" Margin="0,0,0,4" />
            <CheckBox Content="Show toast notification on auto-mute" IsChecked="True" Margin="0,0,0,4" />
            <CheckBox Content="Show tray warning when likely away" IsChecked="True" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Padding="12,6" Margin="0,0,8,0" x:Name="SaveButton"
                    Visibility="Collapsed" Click="Save_Click" />
            <Button Content="Close" Padding="12,6" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>

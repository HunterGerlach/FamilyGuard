<Window x:Class="FamilyGuard.UI.Views.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FamilyGuard.UI.ViewModels"
        Title="DaD — Status" Height="430" Width="520"
        MinHeight="430" MinWidth="520"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:StatusViewModel />
    </Window.DataContext>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="DaD Status" Style="{StaticResource PageTitle}" />
        <TextBlock Grid.Row="2" Style="{StaticResource HelpText}"
                   Text="A transparent snapshot of what DaD is monitoring right now. DaD never records audio, reads messages, captures screenshots, or logs keystrokes." />

        <Border Grid.Row="4" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Monitoring" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MonitoringStatus}" VerticalAlignment="Center" FontWeight="SemiBold" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Current user" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentUser}" VerticalAlignment="Center" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Microphone" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MicDeviceName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Mic state" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MicState}" VerticalAlignment="Center" FontWeight="SemiBold" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Presence" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PresenceState}" VerticalAlignment="Center" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Inactive time" VerticalAlignment="Center" Foreground="{StaticResource DadMutedInkBrush}" />
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding InactiveSeconds, StringFormat={}{0:F0} seconds}" VerticalAlignment="Center" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Last action" VerticalAlignment="Top" Foreground="{StaticResource DadMutedInkBrush}" Margin="0,7,0,0" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LastPolicyAction}" VerticalAlignment="Center" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Mute Now" Margin="0,0,8,0" ToolTip="Manual microphone control will be available when the agent connection is wired." />
            <Button Content="Unmute" Margin="0,0,8,0" ToolTip="DaD never auto-unmutes; a user must choose to unmute." />
            <Button Content="Close" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
